{
  "name": "levi-portfolio-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "bash ./scripts/setup.sh",
    "clean": "rm -rf apps/web/dist packages/ui/storybook-static coverage",
    "dev": "pnpm --filter @levi/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test",
    "lint": "eslint apps packages",
    "storybook": "pnpm --filter @levi/ui storybook",
    "build-storybook": "pnpm --filter @levi/ui build-storybook"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0"
  }
}
